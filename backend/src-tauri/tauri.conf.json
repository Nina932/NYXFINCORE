{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "FinAI Platform",
  "version": "1.0.0",
  "identifier": "com.finai.platform",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://127.0.0.1:9200/static/FinAI_Platform_v7.html"
  },
  "app": {
    "windows": [
      {
        "title": "FinAI Platform - Financial Intelligence",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:9200 ws://127.0.0.1:9200; connect-src 'self' http://127.0.0.1:9200 ws://127.0.0.1:9200 https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/finai-backend"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true
    }
  }
}
