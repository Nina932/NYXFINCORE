# FinAI Institutional Platform — Production Secrets Template
# Path: .env.production
# Note: Never commit secrets to version control. Add these to Vercel/GitHub Secrets!

# ── Database (Neon PostgreSQL) ──
DATABASE_URL=postgresql://user:password@region.neon.tech/finai?sslmode=require

# ── Intelligence (OpenAI) ──
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGENT_MODEL=gpt-4o

# ── Operational Environment ──
APP_ENV=production
DEBUG=False
SECRET_KEY=generate-a-long-random-string-here-using-openssl-rand-hex-32

# ── GitHub Actions / Vercel ──
# Note: These are only for CI/CD setup
VERCEL_TOKEN=xxxxxxxxxxxx
VERCEL_ORG_ID=xxxxxxxxxxxx
VERCEL_PROJECT_ID=xxxxxxxxxxxx

# ── Reverse ETL / 1C Integration ──
WRITEBACK_USER=admin_finai
WRITEBACK_PASSWORD=xxxxxxxxxxxx
WRITEBACK_ENDPOINT=https://your-1c-instance.com/odata/standard.odata

# ── Observability ──
OTEL_MODE=enabled
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx/yyyy/zzzz
