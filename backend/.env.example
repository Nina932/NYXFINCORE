# FinAI Backend — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# All keys below are placeholders — replace before running.

# =============================================================================
# Application
# =============================================================================
APP_NAME=FinAI Financial Intelligence
APP_VERSION=2.0.0
APP_ENV=development               # development | staging | production
DEBUG=false                        # true for local dev only
SECRET_KEY=CHANGE_ME_generate-a-random-32-char-string

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=9200
WORKERS=4                          # production: CPUs x 2 + 1
RELOAD=false                       # true for local dev only

# =============================================================================
# Database
# =============================================================================
# SQLite (development / simple deployment)
# Default: sqlite+aiosqlite:///./data/finai.db
# PostgreSQL: postgresql+asyncpg://finai:your_password@localhost:5432/finai_db
DATABASE_URL=sqlite+aiosqlite:///./data/finai.db
DB_PASSWORD=topsecret
# PostgreSQL (production — recommended)
# DATABASE_URL=postgresql+asyncpg://finai_user:STRONG_PASSWORD@localhost:5432/finai_db

# =============================================================================
# Anthropic AI (primary LLM)
# =============================================================================
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# =============================================================================
# Multi-Agent System
# =============================================================================
AGENT_MODE=multi                   # multi = multi-agent system active

# =============================================================================
# Ollama Local LLM (fallback when Claude API unavailable)
# =============================================================================
# Install Ollama: https://ollama.com
# Then run: ollama pull mistral:7b
# No env vars needed — auto-detected on localhost:11434

# =============================================================================
# NVIDIA Nemotron API (optional LLM provider)
# =============================================================================
# Get your key from https://build.nvidia.com/nvidia/nemotron-3-super-120b-a12b
NVIDIA_API_KEY=your-nvidia-api-key-here

# =============================================================================
# Google Gemini API (optional — supports Georgian language)
# =============================================================================
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# File Handling
# =============================================================================
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=xlsx,xls,csv

# =============================================================================
# Security & Authentication
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://yourdomain.com
JWT_SECRET=CHANGE_ME_generate-a-random-jwt-secret-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
REQUIRE_AUTH=true                  # true = all endpoints require authentication

# =============================================================================
# Company Defaults
# =============================================================================
COMPANY_NAME=Your Company Name
DEFAULT_CURRENCY=GEL
DEFAULT_PERIOD=January 2025

# =============================================================================
# SMTP / Email (Scheduled Reports)
# =============================================================================
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=FinAI Reports <your-email@gmail.com>

# =============================================================================
# Currency / Exchange Rates
# =============================================================================
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest
EXCHANGE_RATE_API_KEY=
SUPPORTED_CURRENCIES=GEL,USD,EUR,GBP,TRY

# =============================================================================
# Scheduler (periodic report generation)
# =============================================================================
SCHEDULER_ENABLED=false
SCHEDULER_CHECK_INTERVAL=60       # seconds between scheduler ticks

# =============================================================================
# Redis Cache (optional — falls back to in-memory if unavailable)
# =============================================================================
REDIS_ENABLED=false
REDIS_URL=                         # e.g. redis://localhost:6379/0
REDIS_PREFIX=finai:

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FILE=./logs/finai.log

# =============================================================================
# 1C Chart of Accounts (optional — path to XLSX with hybrid Georgian/IFRS COA)
# =============================================================================
# COA_FILE_PATH=/path/to/1c_AccountN.xlsx
